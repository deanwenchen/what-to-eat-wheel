pinAgain"):"Spin Again!";var sl=(2*Math.PI)/opts.length,na=(2*Math.PI-(currentAngle%(2*Math.PI)))%(2*Math.PI);var idx=Math.floor(na/sl)%opts.length;document.getElementById("resultFood").textContent=opts[idx];var tl=getTaglines();document.getElementById("resultTagline").textContent=tl[Math.floor(Math.random()*tl.length)];resultArea.classList.remove("hidden");}}anim();}spinBtn.addEventListener("click",spin);updateBtn.addEventListener("click",function(){currentAngle=0;drawWheel(getOptions());});window.calculate=function(){};drawWheel(getOptions());})();
  </script>
